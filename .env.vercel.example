APP_NAME="Form CBT"
APP_ENV=production
APP_KEY=base64:PASTE_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://your-vercel-app.vercel.app
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stderr
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Neon/Vercel Postgres. Isi salah satu:
# 1. DB_URL=postgresql://...
# 2. DATABASE_URL=postgresql://...
# 3. POSTGRES_URL=postgresql://...
DB_CONNECTION=pgsql
DB_URL=
DATABASE_URL=
POSTGRES_URL=
DB_SSLMODE=require

VIEW_COMPILED_PATH=/tmp/form-cbt/storage/framework/views
APP_STORAGE_PATH=/tmp/form-cbt/storage

VITE_APP_NAME="${APP_NAME}"
